                    ],
                    "type": "title",
                    "angle": 0,
                    "index": 0,
                    "content": "IMPORT LINK TEXT FILES"
                },
                {
                    "bbox": [
                        61,
                        99,
                        485,
                        114
                    ],
                    "type": "title",
                    "angle": 0,
                    "index": 1,
                    "content": "PATHLOSS RADIO AND ANTENNA FILES CROSS REFERENCE"
                },
                {
                    "bbox": [
                        57,
                        119,
                        569,
                        155
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 2,
                    "merge_prev": false,
                    "content": "A radio and antenna data files cross reference has been added to the Import link text files operation. This feature allows an interference calculation to be carried out immediately following the import. External text files are used to cross reference the radio and antenna identifiers used in the import data to the Pathloss radio and antenna code files."
                },
                {
                    "bbox": [
                        57,
                        162,
                        567,
                        200
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 3,
                    "merge_prev": false,
                    "content": "The Pathloss code files are used to fill in any missing information in the import data. For example if the import data contains only the transmit power and the radio identifier, the receiver threshold information would be read from the cross referenced Pathloss radio code file, but the transmit power would not be changed."
                },
                {
                    "bbox": [
                        58,
                        207,
                        431,
                        219
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 4,
                    "merge_prev": false,
                    "content": "The cross reference files are ASCII text files which meet the following requirements:"
                },
                {
                    "bbox": [
                        58,
                        227,
                        568,
                        321
                    ],
                    "type": "list",
                    "angle": 0,
                    "index": 5,
                    "blocks": [
                        {
                            "bbox": [
                                58,
                                227,
                                568,
                                250
                            ],
                            "type": "text",
                            "angle": 0,
                            "index": 6,
                            "lines": [
                                {
                                    "bbox": [
                                        58,
                                        226,
                                        570,
                                        240
                                    ],
                                    "spans": [
                                        {
                                            "bbox": [
                                                58,
                                                226,
                                                570,
                                                240
                                            ],
                                            "type": "text",
                                            "content": "• The file names must be “ant_xref.txt” and “rad_xref.txt” for the antennas and radios cross reference files respec-",
                                            "score": 1.0
                                        }
                                    ]
                                },
                                {
                                    "bbox": [
                                        72,
                                        238,
                                        501,
                                        251
                                    ],
                                    "spans": [
                                        {
                                            "bbox": [
                                                72,
                                                238,
                                                501,
                                                251
                                            ],
                                            "type": "text",
                                            "content": "tively. These files must be located in the same directory that the Pathloss program is installed in.",
                                            "score": 1.0
                                        }
                                    ]
                                }
                            ],
                            "merge_prev": false
                        },
                        {
                            "bbox": [
                                58,
                                256,
                                567,
                                280
                            ],
                            "type": "text",
                            "angle": 0,
                            "index": 7,
                            "lines": [
                                {
                                    "bbox": [
                                        59,
                                        254,
                                        567,
                                        269
                                    ],
                                    "spans": [
                                        {
                                            "bbox": [
                                                59,
                                                254,
                                                567,
                                                269
                                            ],
                                            "type": "text",
                                            "content": "• Each line in the file must consist of the import data descriptor in double quotes followed by the Pathloss code file",
                                            "score": 1.0
                                        }
                                    ]
                                },
                                {
                                    "bbox": [
                                        72,
                                        268,
                                        230,
                                        281
                                    ],
                                    "spans": [
                                        {
                                            "bbox": [
                                                72,
                                                268,
                                                230,
                                                281
                                            ],
                                            "type": "text",
                                            "content": "name separated by a space or tab.",
                                            "score": 1.0
                                        }
                                    ]
                                }
                            ],
                            "merge_prev": false
                        },
                        {
                            "bbox": [
                                58,
                                285,
                                567,
                                321
                            ],
                            "type": "text",
                            "angle": 0,
                            "index": 8,
                            "lines": [
                                {
                                    "bbox": [
                                        67,
                                        283,
                                        568,
                                        298
                                    ],
                                    "spans": [
                                        {
                                            "bbox": [
                                                67,
                                                283,
                                                568,
                                                298
                                            ],
                                            "type": "text",
                                            "content": "The comparison in the cross reference is not case sensitive; however the spelling in the cross reference file must",
                                            "score": 1.0
                                        }
                                    ]
                                },
                                {
                                    "bbox": [
                                        73,
                                        297,
                                        568,
                                        310
                                    ],
                                    "spans": [
                                        {
                                            "bbox": [
                                                73,
                                                297,
                                                568,
                                                310
                                            ],
                                            "type": "text",
                                            "content": "be the same as the data file. If there are several variants in the import data file, then a cross reference line must",
                                            "score": 1.0
                                        }
                                    ]
                                },
                                {
                                    "bbox": [
                                        73,
                                        308,
                                        493,
                                        321
                                    ],
                                    "spans": [
                                        {
                                            "bbox": [
                                                73,
                                                308,
                                                493,
                                                321
                                            ],
                                            "type": "text",
                                            "content": "be created for each variant. The same Pathloss code file name could be used for each variant.",
                                            "score": 1.0
                                        }
                                    ]
                                }
                            ],
                            "merge_prev": false
                        }
                    ],
                    "sub_type": "text"
                },

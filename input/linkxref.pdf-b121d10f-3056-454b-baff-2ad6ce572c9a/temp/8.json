                                        {
                                            "bbox": [
                                                73,
                                                297,
                                                568,
                                                310
                                            ],
                                            "type": "text",
                                            "content": "giống với tệp dữ liệu. Nếu có một số biến thể trong tệp dữ liệu nhập, thì phải tạo một dòng tham chiếu chéo",
                                            "score": 1.0

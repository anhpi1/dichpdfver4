                                            "bbox": [
                                                72,
                                                106,
                                                568,
                                                121
                                            ],
                                            "type": "text",
                                            "content": "loss. An option has been added to not calculate the tropospheric scatter loss. This option is available in",
                                            "score": 1.0
                                        }
                                    ]
                                },

                    ],
                    "type": "title",
                    "angle": 0,
                    "index": 7,
                    "content": "Section Operations"
                },
                {
                    "bbox": [
                        57,
                        221,
                        367,
                        290
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 8,
                    "merge_prev": false,
                    "content": "Pathloss file operations for point to point and point to multipoint applications can now use existing file associations. In addition optional template operations have been provided for radios - du- plexers and antennas and transmission lines. Several possibilities with these features include:"
                },
                {
                    "bbox": [
                        58,
                        301,
                        365,
                        389
                    ],
                    "type": "list",
                    "angle": 0,
                    "index": 9,
                    "blocks": [
                        {
                            "bbox": [
                                58,
                                301,
                                365,
                                329
                            ],
                            "type": "text",
                            "angle": 0,
                            "index": 10,
                            "lines": [
                                {
                                    "bbox": [
                                        71,
                                        300,
                                        367,
                                        316
                                    ],
                                    "spans": [
                                        {
                                            "bbox": [
                                                71,
                                                300,
                                                367,
                                                316
                                            ],
                                            "type": "text",
                                            "content": "create new path profiles for several sites which have moved,",
                                            "score": 1.0
                                        }
                                    ]
                                },
                                {
                                    "bbox": [
                                        72,
                                        315,
                                        291,
                                        330
                                    ],
                                    "spans": [
                                        {
                                            "bbox": [
                                                72,
                                                315,
                                                291,
                                                330
                                            ],
                                            "type": "text",
                                            "content": "but retain all existing equipment parameters.",
                                            "score": 1.0
                                        }
                                    ]
                                }
                            ],
                            "merge_prev": false
                        },
                        {
                            "bbox": [

    {
        "type": "chart",
        "img_path": "images/37b4e4449d66410a5d59d9812de26b9d4b1b9808dd80148c1f48c739b65d111e.jpg",
        "content": "| Category | Value |\n| -------- | ----- |\n| Red      | 120   |\n| Blue     | 150   |\n| Green    | 80    |",
        "chart_caption": [],

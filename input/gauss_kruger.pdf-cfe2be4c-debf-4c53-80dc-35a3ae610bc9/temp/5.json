                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 1,
                    "merge_prev": false,
                    "content": "Gauss Kruger",
                    "original_bbox": [
                        68,
                        84,
                        272,
                        173
                    ]
                },
                {
                    "bbox": [
                        68,
                        175,
                        611,
                        216
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 3,
                    "merge_prev": false,
                    "content": "Hệ tọa độ Gauss Kruger được triển khai như một phép chiếu Transverse Mercator tổng quát. Các tham số cụ thể được thiết lập trong hộp thoại Geographic Defaults. Chọn Configure - Geographic defaults. Đặt hệ tọa độ lưới [2] thành Gauss Kruger. Nút định nghĩa tham số Gauss Kruger sẽ hoạt động khi lựa chọn tọa độ lưới được thực hiện.",
                    "original_bbox": [
                        68,
                        175,
                        530,
                        202
                    ]
                },
                {
                    "type": "table",
                    "bbox": [
                        110,
                        217,
                        536,
                        578
                    ],
                    "index": 4,
                    "image_path": "1f48898800b03675a489256bcb46f50a690b9de2b96315117a40c08b97973203.jpg",
                    "original_bbox": [
                        110,
                        217,
                        536,
                        578
                    ]
                },
                {
                    "bbox": [
                        68,
                        594,
                        611,
                        638
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 5,
                    "merge_prev": false,
                    "content": "Kinh độ và vĩ độ gốc có thể được nhập dưới dạng độ thập phân hoặc độ phút giây với khoảng trắng phân cách các giá trị.",
                    "original_bbox": [
                        68,
                        594,
                        540,
                        624
                    ]
                },
                {
                    "bbox": [
                        68,
                        639,
                        611,
                        668
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 6,
                    "merge_prev": false,
                    "content": "Nút Swedish Grid thiết lập các tham số cho hệ tọa độ lưới Thụy Điển.",
                    "original_bbox": [
                        68,
                        639,
                        453,
                        653
                    ]
                },
                {
                    "bbox": [
                        67,
                        669,
                        611,
                        791
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 7,
                    "merge_prev": false,
                    "content": "Khi các định nghĩa hoàn tất, đóng hộp thoại bằng nút OK. Các tham số sẽ được lưu trong tệp có tên gauskrug.bin trong thư mục chương trình pathloss. Tất cả các chuyển đổi giữa tọa độ địa lý và easting - northings sẽ sử dụng các định nghĩa này.",
                    "original_bbox": [
                        67,
                        669,
                        537,
                        715
                    ]
                }
            ]
        },
        {

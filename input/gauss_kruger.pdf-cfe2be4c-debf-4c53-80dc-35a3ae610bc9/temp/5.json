                        51,
                        159,
                        65
                    ]
                },
                {
                    "bbox": [
                        67,
                        81,
                        611,
                        139
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 1,
                    "merge_prev": false,
                    "content": "Ngoài các tham số Transverse Mercator đã chỉ định, việc chuyển đổi giữa tọa độ địa lý và easting - northings dựa trên định nghĩa ellipsoid. Cả hai ellipsoid Bessel và Krassovsky đều được sử dụng. Do đó, bạn phải chọn một ellipsoid và đánh dấu nút Use Ellipsoid trong hộp thoại Geographic defaults.",
                    "original_bbox": [
                        67,
                        81,
                        518,
                        140
                    ]
                },
                {

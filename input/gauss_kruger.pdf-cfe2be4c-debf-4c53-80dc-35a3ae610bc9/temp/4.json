                        173
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 1,
                    "merge_prev": false,
                    "content": "Gauss Kruger"
                },
                {
                    "type": "image",
                    "bbox": [
                        276,
                        50,
                        541,
                        168
                    ],
                    "index": 2,
                    "sub_type": "text_image",
                    "image_path": "561fbf26d618f5b36d21b7e3a703316f1ca66ad3e897063dda7ca45ad785e5c9.jpg"
                },
                {
                    "bbox": [
                        68,
                        175,
                        530,
                        202
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 3,
                    "merge_prev": false,
                    "content": "Hệ tọa độ Gauss Kruger được triển khai như một phép chiếu Transverse Mercator tổng quát. Các tham số cụ thể được thiết lập trong hộp thoại Geographic Defaults. Chọn Configure - Geographic defaults. Đặt hệ tọa độ lưới [2] thành Gauss Kruger. Nút định nghĩa tham số Gauss Kruger sẽ hoạt động khi lựa chọn tọa độ lưới được thực hiện."
                },
                {
                    "type": "table",
                    "bbox": [
                        110,
                        217,
                        536,
                        578
                    ],
                    "index": 4,
                    "image_path": "1f48898800b03675a489256bcb46f50a690b9de2b96315117a40c08b97973203.jpg"
                },
                {
                    "bbox": [
                        68,
                        594,
                        540,
                        624
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 5,
                    "merge_prev": false,
                    "content": "Kinh độ và vĩ độ gốc có thể được nhập dưới dạng độ thập phân hoặc độ phút giây với khoảng trắng phân cách các giá trị."
                },
                {
                    "bbox": [
                        68,
                        639,
                        453,
                        653
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 6,
                    "merge_prev": false,
                    "content": "Nút Swedish Grid thiết lập các tham số cho hệ tọa độ lưới Thụy Điển."
                },
                {
                    "bbox": [
                        67,
                        669,
                        537,
                        715
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 7,
                    "merge_prev": false,
                    "content": "Khi các định nghĩa hoàn tất, đóng hộp thoại bằng nút OK. Các tham số sẽ được lưu trong tệp có tên gauskrug.bin trong thư mục chương trình pathloss. Tất cả các chuyển đổi giữa tọa độ địa lý và easting - northings sẽ sử dụng các định nghĩa này."
                }
            ]
        },
        {
            "discarded_blocks": [],
            "page_size": [
                612,
                792
            ],
            "page_idx": 1,
            "para_blocks": [
                {
                    "bbox": [
                        69,
                        51,
                        159,
                        65
                    ],
                    "type": "title",
                    "angle": 0,
                    "index": 0,
                    "content": "Ellipsoid - Datum"
                },
                {
                    "bbox": [
                        67,
                        81,
                        518,
                        140
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 1,
                    "merge_prev": false,
                    "content": "Ngoài các tham số Transverse Mercator đã chỉ định, việc chuyển đổi giữa tọa độ địa lý và easting - northings dựa trên định nghĩa ellipsoid. Cả hai ellipsoid Bessel và Krassovsky đều được sử dụng. Do đó, bạn phải chọn một ellipsoid và đánh dấu nút Use Ellipsoid trong hộp thoại Geographic defaults."
                },
                {
                    "bbox": [
                        68,
                        141,
                        265,
                        171
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 2,
                    "merge_prev": false,
                    "content": "Lưu ý rằng không có datum nào tương ứng với hai ellipsoid này."
                },
                {
                    "type": "image",
                    "bbox": [
                        286,
                        140,
                        531,
                        186
                    ],
                    "index": 3,
                    "sub_type": "text_image",
                    "image_path": "6615a59357f23777afb1b7fff8ee2decca6db64fc472b042fd60e4048139132a.jpg"
                },
                {
                    "bbox": [
                        69,
                        186,
                        162,
                        199
                    ],
                    "type": "title",
                    "angle": 0,
                    "index": 4,
                    "content": "Cơ sở dữ liệu địa hình"
                },
                {
                    "bbox": [
                        67,
                        216,
                        535,
                        276
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 5,
                    "merge_prev": false,
                    "content": "Tùy chọn cơ sở dữ liệu địa hình Odyssey - Gauss Kruger đã được triển khai cho phép chiếu này. Tùy chọn này có thể được sử dụng với bất kỳ cơ sở dữ liệu địa hình nào có độ cao được sắp xếp theo hàng từ tây sang đông như MSI Planet. Các định nghĩa Gauss Kruger cũng có thể được thiết lập như một phần của cấu hình cơ sở dữ liệu. Điều này tương tự như việc thiết lập các tham số trong Geographic defaults."
                },
                {
                    "bbox": [
                        67,
                        291,
                        536,
                        365
                    ],
                    "type": "text",
                    "angle": 0,
                    "index": 6,
                    "merge_prev": false,
                    "content": "Một vấn đề có thể xảy ra khi tạo chỉ mục cho cơ sở dữ liệu Gauss Kruger từ tệp văn bản. Đặc tả cạnh đông và cạnh tây có thể bao gồm số vùng làm chữ số đầu tiên của giá trị. Quá trình chuyển đổi kiểm tra giá trị của cạnh đông và cạnh tây. Nếu giá trị lớn hơn 1000, chữ số đầu tiên sẽ bị loại bỏ. Trong hầu hết các trường hợp, kết quả sẽ chính xác; tuy nhiên, một giá trị lớn hơn 1000 cũng có thể là một easting thực tế."
                },
                {
